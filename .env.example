# Copy this file to .env and fill in your values.
# .env is loaded automatically by app.py via python-dotenv.

# --- Flask ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# --- Admin login ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Infobip WhatsApp ---
# API key from https://portal.infobip.com → API Keys
INFOBIP_API_KEY=your_infobip_api_key

# Base URL shown on your Infobip dashboard (without https://)
# Example: xxxxx.api.infobip.com
INFOBIP_BASE_URL=xxxxx.api.infobip.com

# Your registered WhatsApp sender number (digits only, with country code, no + or spaces)
# Example: 385912345678
INFOBIP_SENDER=your_sender_number

# Recipient WhatsApp number (digits only, with country code, no + or spaces)
# Example: 48500123456
TO_WHATSAPP=recipient_number
